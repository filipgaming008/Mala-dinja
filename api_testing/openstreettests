MACEDONIA_ID="53293"
MACEDONIA_BBOX="40.852478,20.4529023,42.3739044,23.034051"


import requests
import json

overpass_url = "https://overpass.kumi.systems/api/interpreter"

overpass_query_vardar=f"""
/*
This has been generated by the overpass-turbo wizard.
The original search was:
“waterway=river and name=Vardar and type:way”
*/
[out:json][timeout:25][bbox:{MACEDONIA_BBOX}];
// gather results
way["waterway"="river"]["name"="Вардар"];
// print results
out geom;"""



response = requests.post(overpass_url, data={'data': overpass_query_vardar})


data = response.json()
for element in data.get('elements', []):
    points = element.get('geometry', [])

    for i, point in enumerate(points):
        lat = point['lat']
        lon = point['lon']
        print(f"Point {i}: Lat {lat}, Lon {lon}")
